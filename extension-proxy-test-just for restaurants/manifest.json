{
  "manifest_version": 3,
  "name": "G-Maps Extractor (Proxy Test)",
  "version": "2.0.0",
  "description": "Extract leads from Google Maps using Proxy + Fetch interception",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://maps.google.com/*",
    "https://gle3-git-main-rimenehmaid-3753s-projects.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://maps.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://www.google.com/*", "https://maps.google.com/*"]
    }
  ]
}
