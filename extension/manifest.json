{
  "manifest_version": 3,
  "name": "Google Maps Lead Extractor",
  "version": "1.0.0",
  "description": "Extract business leads from Google Maps search results",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads",
    "identity"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://www.google.co.uk/maps/*",
    "https://www.google.fr/maps/*",
    "https://www.google.it/maps/*",
    "https://www.google.de/maps/*",
    "https://www.google.es/maps/*",
    "https://www.google.tn/maps/*",
    "https://*.vercel.app/*"
  ],
  "oauth2": {
    "client_id": "373635363134-bf3nbcom0hdskjriegmi9iv0g1edhsav.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Maps Lead Extractor",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://www.google.co.uk/maps/*",
        "https://www.google.fr/maps/*",
        "https://www.google.it/maps/*",
        "https://www.google.de/maps/*",
        "https://www.google.es/maps/*",
        "https://www.google.tn/maps/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
